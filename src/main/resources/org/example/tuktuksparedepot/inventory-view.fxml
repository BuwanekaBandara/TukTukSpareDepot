<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.tuktuksparedepot.ui.InventoryController">
   <top>
      <VBox prefHeight="200.0" prefWidth="100.0" spacing="10.0" style="-fx-background-color: #bac5bd;" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
         <children>
            <Label contentDisplay="TOP" text="Malabe Tuk-Tuk &amp; Three-Wheeler Spares Depot">
               <font>
                  <Font name="Cambria Bold" size="24.0" />
               </font>
               <padding>
                  <Insets bottom="10.0" right="15.0" top="15.0" />
               </padding>
            </Label>
            <Label fx:id="lowStockLabel" contentDisplay="TOP" layoutX="25.0" layoutY="25.0" text="Low Stock: None" textFill="#ff0404">
               <font>
                  <Font name="Calibri Bold Italic" size="18.0" />
               </font>
               <padding>
                  <Insets bottom="5.0" />
               </padding>
            </Label>
            <HBox prefHeight="100.0" prefWidth="200.0" spacing="10.0">
               <children>
                  <Button fx:id="addPartBtn" mnemonicParsing="false" style="-fx-background-color: #0c4420;" text="Add Part" textFill="WHITE" onAction="#handleAddPart" />
                  <Button fx:id="editPartBtn" layoutX="10.0" layoutY="10.0" mnemonicParsing="false" style="-fx-background-color: #0c4420;" text="Edit Part" textFill="WHITE" onAction="#handleEditPart" />
                  <Button fx:id="deletePartBtn" layoutX="72.0" layoutY="10.0" mnemonicParsing="false" onAction="#handleDeletePart" style="-fx-background-color: #0c4420;" text="Delete Part" textFill="WHITE" />
                  <Button fx:id="searchBtn" layoutX="135.0" layoutY="10.0" mnemonicParsing="false" style="-fx-background-color: #0c4420;" text="Search" textFill="WHITE" onAction="#handleSearch"/>
                  <Button fx:id="cartBtn" layoutX="197.0" layoutY="10.0" mnemonicParsing="false" style="-fx-background-color: #0c4420;" text="Cart" textFill="WHITE" />
                  <Button fx:id="dealersBtn" layoutX="260.0" layoutY="10.0" mnemonicParsing="false" style="-fx-background-color: #0c4420;" text="Dealers" textFill="WHITE" onAction="#handleDealers" />
               </children>
               <padding>
                  <Insets bottom="10.0" />
               </padding>
            </HBox>
            <HBox prefHeight="100.0" prefWidth="200.0">
               <children>
                  <Label fx:id="totalPartsLabel" text="Total Parts: 0">
                     <font>
                        <Font name="Calibri" size="18.0" />
                     </font>
                     <padding>
                        <Insets right="50.0" />
                     </padding>
                  </Label>
                  <Label fx:id="totalValueLabel" layoutX="10.0" layoutY="10.0" text="Total Value: Rs. 0">
                     <font>
                        <Font name="Calibri" size="18.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
         </children>
      </VBox>
   </top>
   <center>
      <TableView fx:id="inventoryTable" prefHeight="600.0" prefWidth="200.0" BorderPane.alignment="CENTER_LEFT">
        <columns>
          <TableColumn fx:id="partCodeCol" text="Part Code" />
          <TableColumn fx:id="partNameCol" prefWidth="200.0" text="Part Name" />
            <TableColumn fx:id="brandCol" prefWidth="100.0" text="Brand" />
            <TableColumn fx:id="priceCol" text="Price" />
            <TableColumn fx:id="quantityCol" prefWidth="70.0" text="Quantity" />
            <TableColumn fx:id="categoryCol" prefWidth="100.0" text="Category" />
            <TableColumn fx:id="dateCol" prefWidth="100.0" text="Date" />
            <TableColumn fx:id="availabilityCol" prefWidth="100.0" text="Availability" />
        </columns>
         <BorderPane.margin>
            <Insets />
         </BorderPane.margin>
      </TableView>
   </center>
   <bottom>
      <Button fx:id="clearSelectionBtn" mnemonicParsing="false" style="-fx-background-color: #ff0000;" text="Clear Selection" textFill="WHITE" BorderPane.alignment="BOTTOM_RIGHT" onAction="#handleClearSelection">
         <BorderPane.margin>
            <Insets bottom="10.0" right="20.0" top="10.0" />
         </BorderPane.margin>
      </Button>
   </bottom>
</BorderPane>
