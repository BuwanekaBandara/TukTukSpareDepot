<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #bac5bd;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.tuktuksparedepot.ui.DealersController">
   <bottom>
      <ButtonBar buttonMinWidth="50.0" nodeOrientation="LEFT_TO_RIGHT" prefHeight="40.0" prefWidth="200.0" BorderPane.alignment="CENTER_LEFT">
        <buttons>
          <Button fx:id="RandDealerBtn" mnemonicParsing="false" onAction="#handleRandDealers" style="-fx-background-color: #0c4420;" text="Generate a New Random Set of Dealers" textFill="WHITE">
               <padding>
                  <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
               </padding>
               <font>
                  <Font size="13.0" />
               </font>
            </Button>
            <Button fx:id="closeDealers" mnemonicParsing="false" style="-fx-background-color: #ff0000;" text="Close Window" textFill="WHITE" onAction="#handleCloseWindow"/>
        </buttons>
         <BorderPane.margin>
            <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
         </BorderPane.margin>
      </ButtonBar>
   </bottom>
   <top>
      <Label style="-fx-background-color: #bac5bd;" text="Dealers of Malabe Tuk-Tuk &amp; Three-Wheeler Spares Depot" textFill="#fffdfd" BorderPane.alignment="TOP_LEFT">
         <font>
            <Font name="Calibri Bold" size="24.0" />
         </font>
         <BorderPane.margin>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </BorderPane.margin>
      </Label>
   </top>
   <center>
      <TableView fx:id="dealerTable" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <columns>
          <TableColumn fx:id="dealerIdCol" prefWidth="100.0" text="ID" />
          <TableColumn fx:id="dealerName" prefWidth="200.0" text="Name" />
            <TableColumn fx:id="dealerTp" prefWidth="150.0" text="T.P" />
            <TableColumn fx:id="dealerLoc" prefWidth="150.0" text="Location" />
        </columns>
      </TableView>
   </center>
</BorderPane>
