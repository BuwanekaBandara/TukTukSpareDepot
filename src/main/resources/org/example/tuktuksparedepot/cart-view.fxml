<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="900.0" style="-fx-background-color: #bac5bd;" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.tuktuksparedepot.ui.CartController">
    <top>
        <VBox spacing="10.0">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0"/>
            </padding>
            <children>
                <Label text="Shopping Cart">
                    <font>
                        <Font name="Cambria Bold" size="22.0"/>
                    </font>
                </Label>
                <HBox spacing="10.0" style="-fx-alignment: center-left;">
                    <children>
                        <Label text="Select Part:"/>
                        <ComboBox fx:id="partComboBox" prefWidth="300.0" promptText="Select a part"/>
                        <Label text="Quantity:"/>
                        <TextField fx:id="quantityField" prefWidth="80.0" promptText="0"/>
                        <Button fx:id="addToCartBtn" text="Add to Cart" onAction="#handleAddToCart" style="-fx-background-color: #0c4420;" textFill="WHITE" mnemonicParsing="false"/>
                        <Button fx:id="removeBtn" text="Remove Selected" onAction="#handleRemove" style="-fx-background-color: red;" textFill="WHITE" mnemonicParsing="false"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>
    <center>
        <TableView fx:id="cartTable">
            <columns>
                <TableColumn fx:id="cartCodeCol" text="Part Code" prefWidth="90"/>
                <TableColumn fx:id="cartNameCol" text="Part Name" prefWidth="200"/>
                <TableColumn fx:id="cartPriceCol" text="Unit Price" prefWidth="90"/>
                <TableColumn fx:id="cartQtyCol" text="Quantity" prefWidth="80"/>
                <TableColumn fx:id="cartSubtotalCol" text="Subtotal" prefWidth="100"/>
                <TableColumn fx:id="cartDiscountCol" text="Discount" prefWidth="100"/>
            </columns>
            <BorderPane.margin>
                <Insets bottom="10.0" left="15.0" right="15.0" top="10.0"/>
            </BorderPane.margin>
        </TableView>
    </center>
    <bottom>
        <VBox spacing="8.0">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="10.0"/>
            </padding>
            <children>
                <HBox spacing="20.0">
                    <children>
                        <Label text="Subtotal before discounts:"/>
                        <Label fx:id="subtotalLabel" text="Rs. 0.00"/>
                    </children>
                </HBox>
                <HBox spacing="20.0">
                    <children>
                        <Label text="Bulk Discount (5% on items ≥ 3 units):"/>
                        <Label fx:id="bulkDiscountLabel" text="Rs. 0.00" style="-fx-text-fill: green;"/>
                    </children>
                </HBox>
                <HBox spacing="20.0">
                    <children>
                        <Label text="Synergy Discount (10% - Engine + Electrical):"/>
                        <Label fx:id="synergyDiscountLabel" text="Rs. 0.00" style="-fx-text-fill: green;"/>
                    </children>
                </HBox>
                <HBox spacing="20.0">
                    <children>
                        <Label text="Total:">
                            <font>
                                <Font name="Calibri Bold" size="16.0"/>
                            </font>
                        </Label>
                        <Label fx:id="totalLabel" text="Rs. 0.00" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    </children>
                </HBox>
                <HBox spacing="10.0">
                    <children>
                        <Button fx:id="checkoutBtn" text="Checkout" onAction="#handleCheckout" style="-fx-background-color: #0c4420;" textFill="WHITE" mnemonicParsing="false">
                            <font>
                                <Font size="14.0"/>
                            </font>
                        </Button>
                        <Button fx:id="clearCartBtn" text="Clear Cart" onAction="#handleClearCart" style="-fx-background-color: red;" textFill="WHITE" mnemonicParsing="false">
                            <font>
                                <Font size="14.0"/>
                            </font>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </bottom>
</BorderPane>